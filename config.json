{
  "defaults": {
    "host": "0.0.0.0",
    "port": "8080",
    "threads": "14"
  },

  "common": [
    "--fit", "on",
    "--no-mmap",
    "--mlock",
    "--parallel", "1",
    "--metrics",
    "--kv-unified"
  ],

  "runtimes": {
  "Stable": {
    "windows": "$LLAMA_BIN_STABLE",
    "linux":   "$LINUX_LLAMA_BIN_STABLE"
  },
  "Latest": {
    "windows": "$LLAMA_BIN_LATEST",
    "linux":   "$LINUX_LLAMA_BIN_STABLE"
  }
},

  "profiles": [
    {
      "name": "Qwen 27B 120k",
      "executable": "llama-server.exe",
      "tags": ["reasoning", "coding", "long-context"],
      "notes": [
        "Dense model",
        "MTP variant uses --spec-type draft-mtp",
        "mmproj currently incompatible with MTP - disable vision when using MTP"
      ],
      "models": {
        "lmstudio Q4_K_M": {
          "model":  "$LLAMA_MODELS/lmstudio-community/Qwen3.6-27B-GGUF/Qwen3.6-27B-Q4_K_M.gguf",
          "mmproj": "$LLAMA_MODELS/lmstudio-community/Qwen3.6-27B-GGUF/mmproj-Qwen3.6-27B-BF16.gguf",
          "mtp": false
        },
        "unsloth Q5_K_XL": {
          "model":  "$LLAMA_MODELS/unsloth/Qwen3.6-27B-GGUF/Qwen3.6-27B-UD-Q5_K_XL.gguf",
          "mmproj": "$LLAMA_MODELS/unsloth/Qwen3.6-27B-GGUF/mmproj-F32.gguf",
          "mtp": false
        },
        "unsloth MTP Q4_K_M": {
          "model":  "$LLAMA_MODELS/unsloth/Qwen3.6-27B-MTP-GGUF/Qwen3.6-27B-Q4_K_M.gguf",
          "mmproj": "$LLAMA_MODELS/unsloth/Qwen3.6-27B-MTP-GGUF/mmproj-F32.gguf",
          "mtp": true,
          "mtp_args": ["--spec-type", "draft-mtp", "--spec-draft-n-max", "3"]
        },
        "unsloth MTP Q4_K_XL": {
          "model":  "$LLAMA_MODELS/unsloth/Qwen3.6-27B-MTP-GGUF/Qwen3.6-27B-UD-Q4_K_XL.gguf",
          "mmproj": "$LLAMA_MODELS/unsloth/Qwen3.6-27B-MTP-GGUF/mmproj-F32.gguf",
          "mtp": true,
          "mtp_args": ["--spec-type", "draft-mtp,ngram-mod", "--spec-draft-n-max", "3", "--spec-ngram-mod-n-match", "24", "--spec-ngram-mod-n-min", "12", "--spec-ngram-mod-n-max", "48"]
        },
        "unsloth MTP IQ4_XS": {
          "model":  "$LLAMA_MODELS/unsloth/Qwen3.6-27B-MTP-GGUF/Qwen3.6-27B-IQ4_XS.gguf",
          "mmproj": "$LLAMA_MODELS/unsloth/Qwen3.6-27B-MTP-GGUF/mmproj-F32.gguf",
          "mtp": true,
          "mtp_args": ["--spec-type", "draft-mtp", "--spec-draft-n-max", "3"]
        }
      },
      "tunables": {
        "ctx":    "120000",
        "batch":  "512",
        "ubatch": "512",
        "mmproj": false
      },
      "fixed": [
        "-ngl", "99",
        "--flash-attn", "on",
        "--jinja",
        "--no-mmproj-offload",
        "--cache-type-k", "q8_0", "--cache-type-v", "q8_0",
        "--presence-penalty", "0",
        "--repeat-penalty", "1",
        "--temperature", "0.6",
        "--top-p", "0.95", "--top-k", "20", "--min-p", "0.05",
        "--log-colors", "on",
        "--chat-template-kwargs", "{\"preserve-thinking\":true}",
        "--ctx-checkpoints", "256"
      ]
    },

    {
      "name": "Qwen 35B 262k MOE",
      "executable": "llama-server.exe",
      "tags": ["reasoning", "coding", "long-context", "moe"],
      "notes": [
        "MOE model — n-cpu-moe offloads MOE layers to CPU",
        "MTP variant uses --spec-type draft-mtp",
        "mmproj currently incompatible with MTP — disable vision when using MTP"
      ],
      "models": {
        "lmstudio Q4_K_M": {
          "model":  "$LLAMA_MODELS/lmstudio-community/Qwen3.6-35B-A3B-GGUF/Qwen3.6-35B-A3B-Q4_K_M.gguf",
          "mmproj": "$LLAMA_MODELS/lmstudio-community/Qwen3.6-35B-A3B-GGUF/mmproj-Qwen3.6-35B-A3B-BF16.gguf",
          "mtp": false
        },
        "unsloth Q5_K_XL MTP": {
          "model":  "$LLAMA_MODELS/unsloth/Qwen3.6-35B-A3B-MTP-GGUF/Qwen3.6-35B-A3B-UD-Q5_K_XL.gguf",
          "mmproj": "$LLAMA_MODELS/unsloth/Qwen3.6-35B-A3B-GGUF/mmproj-F32.gguf",
          "mtp": true,
          "mtp_args": ["--spec-type", "draft-mtp,ngram-mod", "--spec-draft-n-max", "3", "--spec-ngram-mod-n-match", "24", "--spec-ngram-mod-n-min", "48", "--spec-ngram-mod-n-max", "64"]
        }
      },
      "tunables": {
        "ctx":       "262144",
        "batch":     "512",
        "ubatch":    "512",
        "n_cpu_moe": "10",
        "mmproj":    false
      },
      "fixed": [
        "-ngl", "99",
        "--flash-attn", "on",
        "--jinja",
        "--cache-type-k", "q8_0", "--cache-type-v", "q8_0",
        "--presence-penalty", "0",
        "--repeat-penalty", "1.0",
        "--top-p", "0.95", "--top-k", "20", "--min-p", "0.05",
        "--temperature", "0.6",
        "--log-colors", "on",
        "--chat-template-kwargs", "{\"preserve-thinking\":true}"
      ]
    },

